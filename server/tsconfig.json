{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "moduleResolution": "Bundler",

    "resolveJsonModule": true,

    "types": ["node"],

    "sourceMap": true,

    "baseUrl": "./src",

    "paths": {
      "@/*": ["*"]
    }
  },

  "include": ["src"],

  "exclude": ["node_modules", "dist"]
}